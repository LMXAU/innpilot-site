{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "innpilot-site",
  "compatibility_date": "2026-07-04",
  "routes": [
    {
      "pattern": "www.innpilot.ai",
      "custom_domain": true,
    },
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page",
  },
}
